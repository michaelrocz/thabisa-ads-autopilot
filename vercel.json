{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/actions/audit",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/actions/audit/meta",
      "schedule": "0 3 * * 1,4"
    },
    {
      "path": "/api/actions/audit",
      "schedule": "30 3 * * 1"
    }
  ]
}
